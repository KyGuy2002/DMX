


#include <MCP_DAC.h>
#include <SPI.h>
#include <Arduino.h>


MCP4921 MCP(15, 14);  //  SW SPI

volatile int x;
uint32_t start, stop;


void setup()
{

  SPI1.begin();

  MCP.begin(13);
}



void loop()
{

  for (int i = 0; i < 4095; i++) {
    MCP.fastWriteA(i);
    delay(1);
  }

  // Serial.println("a");
  // MCP.fastWriteA(4095);
  // delay(1000);
  // MCP.fastWriteA(0);
  // Serial.println("b");
  // delay(1000);
}


