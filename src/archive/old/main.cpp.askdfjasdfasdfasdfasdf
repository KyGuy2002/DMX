/*

SPI Connections:

MOSI:   GP 19
SCK:    GP 18
CS:     GP 17
LDAC:   GP 2

SPI1 Connections:

MOSI:   GP 15
SCK:    GP 14
CS:     GP 13
LDAC:   GP  3


(Experimental) The Pins can be changed at any time via the setGPIO() command, view the Pico Pinout for compatible Pins

*/



#include "MCP_DAC.h"


uint16_t     freq = 10;
uint32_t   period = 0;
uint32_t   halvePeriod = 0;


//  q = square
//  s = sinus
//  w = sawtooth
//  t = triangle
//  r = random
char mode = 'q';


MCP4921 MCP(&SPI1);
uint16_t count;
uint32_t lastTime = 0;


//  LOOKUP TABLE SINE
uint16_t sine[361];


void setup()
{
  Serial.begin(115200);

  //  fill table with sinus values for fast lookup
  for (int i = 0; i < 361; i++)
  {
    sine[i] = 2047 + round(2047 * sin(i * PI / 180));
  }

  SPI1.begin();

  //  MCP.begin(17);    //  select pin = 17, SPI
  MCP.begin(13);    //  select pin = 13, SPI1

  MCP.fastWriteA(0);

  period = 1e6 / freq;
  halvePeriod = period / 2;

  // while (1)
  // {

  //   MCP.fastWriteA(4095);
  // }
}


void loop()
{
  // Serial.println("a");
  MCP.fastWriteA(4095);
  delay(100);
  // MCP.fastWriteA(0);
  // // Serial.println("b");
  // delay(100);

}


